{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate --schema=../prisma/schema.prisma && tsc",
    "start": "node dist/index.js",
    "db:generate": "node ../scripts/prisma.mjs generate",
    "db:push": "node ../scripts/prisma.mjs db push",
    "db:migrate": "node ../scripts/prisma.mjs migrate dev",
    "db:studio": "node ../scripts/prisma.mjs studio"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "prisma": "6.19.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
