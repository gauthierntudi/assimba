{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run vercel-build --prefix ..",
  "outputDirectory": "dist",
  "installCommand": "npm install --prefix .. --include=dev",
  "framework": null,
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/|assets/|img/|vendor/).*)",
      "destination": "/index.html"
    }
  ]
}
