# Neon PostgreSQL (prod) — remplacer par votre URL depuis https://console.neon.tech
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# PostgreSQL local (dev) — lancer : docker compose up -d
DATABASE_URL="postgresql://simba:simba@localhost:5432/simba?schema=public"

# API
PORT=4000
APP_URL=http://localhost:4000
WEB_URL=http://localhost:5173
NODE_ENV=development

# FlexPay
FLEXPAY_MERCHANT=KAIZEN
FLEXPAY_TOKEN="Bearer YOUR_TOKEN"
FLEXPAY_MOBILE_API_URL=https://backend.flexpay.cd/api/rest/v1/paymentService
FLEXPAY_CARD_API_URL=https://cardpayment.flexpay.cd/v1/pay
FLEXPAY_CHECK_API_URL=https://backend.flexpay.cd/api/rest/v1/check

# SMS
SMS_DISTRIBUTION=TWILIO
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=ASSIMBA
UNIKRON_APP_KEY=
UNIKRON_SENDER=UNIKRON

# Admin
ADMIN_PASSWORD_HASH=
JWT_SECRET=change-me-in-production
