# Neon PostgreSQL (prod) — utiliser l'URL *pooler* pour Vercel serverless
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# PostgreSQL local (Homebrew) — docker compose up -d
DATABASE_URL="postgresql://mac@localhost:5432/simba?schema=public"

# API — en prod Vercel, VERCEL_URL est injecté automatiquement si APP_URL/WEB_URL absents
PORT=4000
APP_URL=http://localhost:4000
WEB_URL=http://localhost:5173
NODE_ENV=development

# Client Vite — en prod sur Vercel, laisser /api (même domaine)
# VITE_API_URL=/api

# FlexPay
FLEXPAY_MERCHANT=KAIZEN
FLEXPAY_TOKEN="Bearer YOUR_TOKEN"
FLEXPAY_MOBILE_API_URL=https://backend.flexpay.cd/api/rest/v1/paymentService
FLEXPAY_CARD_API_URL=https://cardpayment.flexpay.cd/v1/pay
FLEXPAY_CHECK_API_URL=https://backend.flexpay.cd/api/rest/v1/check

# SMS
SMS_DISTRIBUTION=TWILIO
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=ASSIMBA
UNIKRON_APP_KEY=
UNIKRON_SENDER=UNIKRON

# Admin
ADMIN_PASSWORD_HASH=
JWT_SECRET=change-me-in-production

# Inscription — profil social et tarifs carte (USD)
PROFIL_SOCIAL=false
PRICE_SIMPLE=1
PRICE_PREMIUM=2
