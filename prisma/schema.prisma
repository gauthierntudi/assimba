generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Supporter {
  id               Int               @id @default(autoincrement())
  firstname        String?
  lastname         String?
  middlename       String?
  gender           String?
  ageRange         String?           @map("age_range")
  phone            String?           @unique
  countryStatus    String?           @map("country_status")
  province         String?
  city             String?
  town             String?
  section          String?
  occupation       String?
  contribution     String?
  merch            String?
  years            Int?
  trainingFreq     String?           @map("training_freq")
  matchFreq        String?           @map("match_freq")
  followMethod     String?           @map("follow_method")
  memberType       String?           @default("simple") @map("member_type")
  socialFb         String?           @map("social_fb")
  socialX          String?           @map("social_x")
  socialIg         String?           @map("social_ig")
  socialTt         String?           @map("social_tt")
  memberNumber     String?           @unique @map("member_number")
  createdAt        DateTime          @default(now()) @map("created_at")
  invoice          Invoice?
  purchaseHistory  PurchaseHistory[]

  @@map("supporters")
}

/// Facture unique par supporter : état courant du paiement d'adhésion.
model Invoice {
  id               Int       @id @default(autoincrement())
  supporterId      Int       @unique @map("supporter_id")
  reference        String?   @unique
  flexpayReference String?   @map("flexpay_reference")
  amount           Decimal?  @db.Decimal(12, 2)
  currency         String?
  paymentType      String?   @map("payment_type")
  paymentPhone     String?   @map("payment_phone")
  status           String    @default("pending")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")
  supporter        Supporter @relation(fields: [supporterId], references: [id])

  @@map("invoices")
}

/// Historique de toutes les tentatives de paiement.
model PurchaseHistory {
  id               Int       @id @default(autoincrement())
  supporterId      Int       @map("supporter_id")
  reference        String    @unique
  flexpayReference String?   @map("flexpay_reference")
  amount           Decimal?  @db.Decimal(12, 2)
  currency         String?
  paymentType      String?   @map("payment_type")
  paymentPhone     String?   @map("payment_phone")
  status           String    @default("pending")
  providerMessage  String?   @map("provider_message")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")
  supporter        Supporter @relation(fields: [supporterId], references: [id])

  @@index([supporterId])
  @@index([flexpayReference])
  @@map("historical_purchases")
}
